{
    "name": "fast-forward/iterators",
    "description": "A robust and optimized library for advanced PHP Iterators.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "php",
        "iterators",
        "iterator utilities",
        "iterator aggregate",
        "iterator iterator",
        "fast-forward"
    ],
    "authors": [
        {
            "name": "Felipe Sayão Lobato Abreu",
            "email": "github@mentordosnerds.com"
        }
    ],
    "homepage": "https://github.com/php-fast-forward",
    "support": {
        "issues": "https://github.com/php-fast-forward/iterators/issues",
        "source": "https://github.com/php-fast-forward/iterators"
    },
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "fast-forward/dev-tools": "dev-main"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "FastForward\\Iterator\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "fast-forward/dev-tools": true,
            "phpdocumentor/shim": true,
            "phpro/grumphp": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "grumphp": {
            "config-default-path": "vendor/fast-forward/dev-tools/grumphp.yml"
        }
    },
    "scripts": {
        "dev-tools": "dev-tools",
        "dev-tools:fix": "@dev-tools --fix"
    }
}
